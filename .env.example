# Local dev: copy to `.env.local` (Next.js loads `.env*.local` in development).
#
# Production: use committed `.env.production` (picked up on `next build` / Vercel),
# or set the same keys in Vercel → Settings → Environment Variables.

NEXT_PUBLIC_WHATSAPP_NUMBER=
